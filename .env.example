# Old Masters Print Shop — environment variables
# Source of truth: TDS §11.2
# Copy to .env.local for development. Production values live in Vercel.

# --- Database ---
# Pooled PostgreSQL connection string (Supabase / Neon / Railway — provider TBD)
DATABASE_URL=

# --- Auth (NextAuth.js v5) ---
# Random 32-byte hex string: `openssl rand -hex 32`
NEXTAUTH_SECRET=
# Canonical site URL (e.g. https://oldmastersprintshop.com)
NEXTAUTH_URL=http://localhost:3000

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Object storage (Cloudflare R2 or AWS S3 — provider TBD) ---
STORAGE_BUCKET_PRIVATE=
STORAGE_BUCKET_PUBLIC=
STORAGE_ACCOUNT_ID=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- CDN ---
# Public base URL for derivative images
CDN_BASE_URL=
